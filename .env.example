# Add the real key as a Hugging Face Space Secret, not as a committed file.
HEXSECGPT_API_KEY=

# Supported provider values for this adapter.
HEXSECGPT_PROVIDER=openrouter

# Optional model override.
HEXSECGPT_MODEL=

# Optional OpenAI-compatible base URL override.
HEXSECGPT_BASE_URL=

# Optional request timeout in seconds.
HEXSECGPT_TIMEOUT_SECONDS=120
